#!/usr/bin/env bash
# notify-email — NOTIFY_CMD handler: emails CI failures via Gmail SMTP using curl
# (no extra packages). Args: <group> <status> <logpath>.
#
# Per-project OR operator-global, with per-variable precedence:
#   1) the project's decrypted secrets (CICD_NOTIFY_ENV, set by the runner from the
#      repo's sops ci/secrets.enc.yaml)  -- repo carries its own email config
#   2) the host default /etc/cicd-runner/notify.env                  -- operator fallback
# Reads the SAME var names Plausible CE uses (so you can reuse that config):
#   SMTP_HOST_ADDR / SMTP_HOST_PORT / SMTP_USER_NAME / SMTP_USER_PWD / MAILER_EMAIL
# Generic aliases also accepted: SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS / NOTIFY_TO
# A project opts in simply by including these keys in its encrypted secrets (+ notify:
# on-failure in ci.yml). Must never block or fail the runner — short timeout, exit 0.
set -uo pipefail

group="${1:-?}"; status="${2:-?}"; logpath="${3:-}"
PROJ="${CICD_NOTIFY_ENV:-}"
HOST_DEF="${CICD_NOTIFY_HOST_ENV:-/etc/cicd-runner/notify.env}"

# getval KEY FILE — extract KEY=val from a dotenv/KEY=VAL file (no sourcing; quote-safe)
getval() {
  [ -n "$2" ] && [ -f "$2" ] || return 0
  grep -m1 -E "^[[:space:]]*$1=" "$2" 2>/dev/null \
    | sed -E "s/^[[:space:]]*$1=//; s/^[\"']//; s/[\"']$//"
}
# read_var KEY [ALIAS] — project file first, then host default, trying KEY then ALIAS
read_var() {
  local v
  for f in "$PROJ" "$HOST_DEF"; do
    v="$(getval "$1" "$f")"; [ -n "$v" ] && { printf '%s' "$v"; return; }
    [ -n "${2:-}" ] && { v="$(getval "$2" "$f")"; [ -n "$v" ] && { printf '%s' "$v"; return; }; }
  done
}
# which tier supplied KEY (or ALIAS): 'project' | 'host' | '' — used to forbid mixing tiers (H5)
tier() {
  [ -n "$(getval "$1" "$PROJ")" ] || { [ -n "${2:-}" ] && [ -n "$(getval "$2" "$PROJ")" ]; } && { printf project; return; }
  [ -n "$(getval "$1" "$HOST_DEF")" ] || { [ -n "${2:-}" ] && [ -n "$(getval "$2" "$HOST_DEF")" ]; } && { printf host; return; }
}

HOST="$(read_var SMTP_HOST_ADDR SMTP_HOST)"; HOST="${HOST:-smtp.gmail.com}"
PORT="$(read_var SMTP_HOST_PORT SMTP_PORT)"; PORT="${PORT:-587}"
USER="$(read_var SMTP_USER_NAME SMTP_USER)"
PASS="$(read_var SMTP_USER_PWD  SMTP_PASS)"
TO="$(read_var NOTIFY_TO MAILER_EMAIL)"; [ -z "$TO" ] && TO="$USER"
FROM="$(read_var MAILER_EMAIL NOTIFY_FROM)"; FROM="${FROM:-$USER}"
[ -n "$USER" ] && [ -n "$PASS" ] && [ -n "$TO" ] || exit 0   # not configured -> skip silently

# H5 open-relay guard: when the SMTP CREDENTIALS are the operator's (host tier), a repo's secrets
# MUST NOT steer the authenticated, SPF/DKIM/DMARC-aligned session. That means NONE of these may
# come from the project tier:
#   * recipient / From      -> open relay (mail anywhere as the operator)
#   * SMTP endpoint addr/port-> credential THEFT (curl AUTHs the operator's user+pass to an
#                               attacker SMTP server before it ever checks where it's sending)
#   * From display-name / Subject / Body -> aligned-but-spoofed phish (e.g. From: "Google
#                               Security <no-reply@accounts.google.com>" on operator-DKIM mail)
# A repo that brings its OWN creds (project tier) may set all of these. Refuse any mix (H3, M1).
if [ "$(tier SMTP_USER_NAME SMTP_USER)" = host ]; then
  for pair in NOTIFY_TO:MAILER_EMAIL MAILER_EMAIL:NOTIFY_FROM \
              SMTP_HOST_ADDR:SMTP_HOST SMTP_HOST_PORT:SMTP_PORT \
              SMTP_FROM_NAME:NOTIFY_FROM_NAME NOTIFY_SUBJECT: NOTIFY_BODY:; do
    if [ "$(tier "${pair%%:*}" "${pair#*:}")" = project ]; then
      printf 'notify-email: REFUSED — project override of %s with host SMTP creds (open-relay/cred-theft guard, H5)\n' "${pair%%:*}"
      exit 0
    fi
  done
fi

# scheme by port: 465 = implicit TLS (smtps); else STARTTLS on smtp:// (587/25)
if [ "$PORT" = "465" ]; then url="smtps://$HOST:$PORT"; else url="smtp://$HOST:$PORT"; fi

# status arrives as "<level>: <message>" (level from notify_success/error/notify).
LEVEL="${status%%:*}"; MESSAGE="${status#*: }"; [ "$MESSAGE" = "$status" ] && MESSAGE="$status"
case "$LEVEL" in
  success|ok|OK) STATUS=success; tag="[CI OK]" ;;
  error|fail)    STATUS=failure; tag="[CI FAIL]" ;;
  *)             STATUS=info;    tag="[CI]" ;;
esac
# only terminal events by default; set NOTIFY_INFO=1 to also mail info notices.
NOTIFY_INFO="$(read_var NOTIFY_INFO)"
[ "$STATUS" = info ] && [ "${NOTIFY_INFO:-0}" != 1 ] && exit 0

# enrich interpolation vars from the run's meta.json (sits beside the log)
META="$(dirname "$logpath")/meta.json"
jget() { sed -n "s/.*\"$1\":\"\\([^\"]*\\)\".*/\\1/p" "$META" 2>/dev/null | head -1; }
REPO="$(jget repo)"; BRANCH="$(jget branch)"; SHA="$(jget sha)"
PUSHER="$(jget pusher)"; EVENT="$(jget event)"; JOB="$(jget job)"
[ -n "$REPO" ] || REPO="$group"
SHORT_SHA="$(printf '%s' "$SHA" | cut -c1-8)"
HOST_NAME="$(hostname 2>/dev/null || echo vps)"
NOW="$(date -u '+%Y-%m-%d %H:%M:%SZ')"
LOGLINES="$(read_var NOTIFY_LOGLINES)"; LOGLINES="${LOGLINES:-30}"
LOGTAIL="$(tail -n "$LOGLINES" "$logpath" 2>/dev/null)"

# custom templates ({{VAR}} tokens) — per-project or host default, else built-ins.
SUBJECT_TMPL="$(read_var NOTIFY_SUBJECT)"
BODY_TMPL="$(read_var NOTIFY_BODY)"
# NB: do NOT fold these defaults into ${VAR:-{{TAG}}…} — the `}}` of a {{TOKEN}} closes the
# parameter expansion early and mangles the template. Assign explicitly when empty.
[ -n "$SUBJECT_TMPL" ] || SUBJECT_TMPL='{{TAG}} {{REPO}}/{{BRANCH}} {{JOB}} — {{STATUS}}'
[ -n "$BODY_TMPL" ] || BODY_TMPL="CI {{STATUS}} on {{HOST}}

repo:    {{REPO}}
branch:  {{BRANCH}}
job:     {{JOB}}
event:   {{EVENT}}
commit:  {{SHORT_SHA}}
pusher:  {{PUSHER}}
time:    {{NOW}}
message: {{MESSAGE}}

--- last $LOGLINES log lines ---
{{LOGTAIL}}"

# literal token substitution (NO eval — message/logtail are untrusted)
render() {
  local t="$1"
  t="${t//\{\{STATUS\}\}/$STATUS}";     t="${t//\{\{TAG\}\}/$tag}"
  t="${t//\{\{REPO\}\}/$REPO}";         t="${t//\{\{BRANCH\}\}/$BRANCH}"
  t="${t//\{\{JOB\}\}/$JOB}";           t="${t//\{\{EVENT\}\}/$EVENT}"
  t="${t//\{\{SHA\}\}/$SHA}";           t="${t//\{\{SHORT_SHA\}\}/$SHORT_SHA}"
  t="${t//\{\{PUSHER\}\}/$PUSHER}";     t="${t//\{\{MESSAGE\}\}/$MESSAGE}"
  t="${t//\{\{LABEL\}\}/$group}";       t="${t//\{\{HOST\}\}/$HOST_NAME}"
  t="${t//\{\{NOW\}\}/$NOW}";           t="${t//\{\{LOGTAIL\}\}/$LOGTAIL}"
  printf '%s' "$t"
}
SUBJECT="$(render "$SUBJECT_TMPL")"; SUBJECT="${SUBJECT//$'\n'/ }"
BODY="$(render "$BODY_TMPL")"

FROM_NAME="$(read_var SMTP_FROM_NAME NOTIFY_FROM_NAME)"; FROM_NAME="${FROM_NAME:-cicd-runner}"
FROM_NAME="$(printf '%s' "$FROM_NAME" | tr -d '\r\n<>')"   # strip CR/LF + angle-brackets: no header injection / fake-address display name
msg="$(printf 'From: %s <%s>\r\nTo: %s\r\nSubject: %s\r\nDate: %s\r\nMIME-Version: 1.0\r\nContent-Type: text/plain; charset=UTF-8\r\n\r\n%s\r\n' \
  "$FROM_NAME" "$FROM" "$TO" "$SUBJECT" "$(date -R 2>/dev/null)" "$BODY")"

# NOTIFY_TO may list several recipients, comma-separated. curl needs ONE --mail-rcpt per
# address (it does not split a comma list), so build the envelope args, trimming spaces.
# The To: header above keeps the full comma list, so all recipients show in the message.
# addrs[] (bare, for the audit line) parallels rcpts[] (--mail-rcpt <addr> for curl).
rcpts=(); addrs=(); IFS=',' read -ra _addrs <<< "$TO"
for a in "${_addrs[@]}"; do
  a="${a#"${a%%[![:space:]]*}"}"; a="${a%"${a##*[![:space:]]}"}"   # trim lead/trail ws
  [ -n "$a" ] && { rcpts+=(--mail-rcpt "$a"); addrs+=("$a"); }
done
[ "${#rcpts[@]}" -gt 0 ] || exit 0                                 # no valid recipient -> skip
joined="$(printf '%s, ' "${addrs[@]}")"; joined="${joined%, }"     # "a@x, b@y" for the log

# capture curl's outcome (stderr) so the caller can record WHO was mailed + OK/FAIL.
# Never blocks or fails the runner: prints one audit line to stdout, always exit 0.
err="$(curl --silent --show-error --max-time 25 --ssl-reqd \
  --url "$url" --user "$USER:$PASS" \
  --mail-from "$FROM" "${rcpts[@]}" \
  --upload-file <(printf '%s' "$msg") 2>&1)"; rc=$?
if [ "$rc" -eq 0 ]; then
  printf 'notify-email: sent %s to %s via %s:%s\n' "$tag" "$joined" "$HOST" "$PORT"
else
  printf 'notify-email: DELIVERY FAILED (curl rc=%s) to %s via %s:%s — %s\n' \
    "$rc" "$joined" "$HOST" "$PORT" "$err"
fi
exit 0
