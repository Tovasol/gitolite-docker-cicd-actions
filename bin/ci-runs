#!/usr/bin/env bash
# ci-runs — emit every run's meta.json as an NDJSON stream (one run per line). This is
# the SEAM between dumb run dirs and any query engine. Each meta.json is already a single
# fat line, so concatenating them IS valid NDJSON. Pipe it anywhere:
#
#   ci-runs | jq -s 'group_by(.job)'      (or duckdb/sqlite over the stream)
#   ci-runs | jq -s 'group_by(.job)'
#   ci-runs tovasol/agent-forge | sqlite3 …          # optional repo-prefix scope (arg 1)
#
# Path is a dumb bucket; meta.json is the source of truth — so every view (latest, by
# branch, by status, timings) is just a query over this stream, never stored state.
set -uo pipefail
CICD_BASE="${CICD_BASE:-/home/cicd-runner/runner}"
# shellcheck disable=SC1090
. "$CICD_BASE/bin/lib.sh"; cicd_load_config

root="$RUNNER_BASE/runs"
[ -n "${1:-}" ] && root="$RUNNER_BASE/runs/$1"
[ -d "$root" ] || exit 0
# Emit only well-formed single-line JSON objects, each enriched with its run dir as a
# "dir" field (the path is otherwise a dumb bucket, absent from meta — but you need it
# to find output.log/cmd). A meta.json half-written during a crash (truncated, no closing
# brace) or any non-JSON is dropped, so the stream a consumer sees is always clean — one
# corrupt run can't break a query. Run dirs are filesystem-safe (no quotes/newlines).
#
# One awk over all files (FNR==1 = the single-line meta; FILENAME = its path) instead of
# a grep+printf per file — O(1) processes, not O(runs). xargs batches the file list.
find "$root" -type f -name meta.json -print0 2>/dev/null \
  | xargs -0 -r awk '
      FNR==1 && /^\{.*\}$/ {
        d = FILENAME; sub(/\/meta\.json$/, "", d)
        print "{\"dir\":\"" d "\"," substr($0, 2)
      }'
