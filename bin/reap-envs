#!/usr/bin/env bash
# reap-envs — cron (daily). The git hook tears down on EVERY gitolite branch delete
# (archive-push, §31), so this only matters for the rare env whose branch vanished
# WITHOUT a hook event (a ref deleted outside gitolite). The runner has NO repo access
# now, so it can't check branch liveness — it uses inactivity age.
# Default: REPORT only (never destroy a quiet-but-live preview). Opt in to auto-teardown
# with AUTO_REAP_STALE_DAYS>0 in runner.conf.
set -uo pipefail
CICD_BASE="${CICD_BASE:-/home/cicd-runner/runner}"
# shellcheck disable=SC1090
. "$CICD_BASE/bin/lib.sh"; cicd_load_config
ZERO=0000000000000000000000000000000000000000

[ -d "$RUNNER_BASE/envs" ] || exit 0
now="$(date -u +%s)"
auto=$(( ${AUTO_REAP_STALE_DAYS:-0} * 86400 ))     # 0 = report only
report=$(( ${REPORT_STALE_DAYS:-30} * 86400 ))

find "$RUNNER_BASE/envs" -maxdepth 2 -mindepth 2 -type d 2>/dev/null | while read -r envdir; do
  rel="${envdir#"$RUNNER_BASE"/envs/}"; repo="${rel%/*}"
  # The branch file lives in the job-controlled /envstate mount, so a job can forge it. recover_env_branch
  # refuses a symlink (F1) AND any content whose slugify() != this env dir's name — i.e. a value forged
  # to redirect the teardown at a DIFFERENT env/tier (F3). The dir name = slugify(trusted branch), set
  # at create, not job-writable — the trust anchor. A tampered env is skipped (it only harms its own cleanup).
  if ! branch="$(recover_env_branch "$envdir")"; then
    log "reap-envs: $rel branch file missing/symlink/invalid/tampered (slug mismatch) — skipping (envstate guard, F3)"
    continue
  fi
  if [ -f "$envdir/teardown-failed" ]; then
    log "reap-envs: $repo/$branch AWAITING OPERATOR (teardown-failed) — ci-teardown retry|abandon"
    continue
  fi
  la="$(stat -c %Y "$envdir" 2>/dev/null || echo "$now")"   # last activity = env dir mtime
  age=$(( now - la ))
  if [ "$auto" -gt 0 ] && [ "$age" -gt "$auto" ]; then
    valid_branch "$branch" || { log "reap-envs: $repo invalid stored branch '$branch' — skipping AUTO teardown (F3)"; continue; }
    log "reap-envs: AUTO teardown stale env $repo/$branch (idle ${age}s)"
    q="$RUNNER_BASE/queue/$repo/$branch"; mkdir -p "$q"
    printf 'delete %s %s reaper\n' "$ZERO" "$ZERO" > "$q/target.tmp"; mv -f "$q/target.tmp" "$q/target"
    setsid "$CICD_BASE/bin/run-group.sh" "$repo" "$branch" </dev/null >>"$RUNNER_BASE/runner.log" 2>&1 &
  elif [ "$age" -gt "$report" ]; then
    log "reap-envs: STALE $repo/$branch idle ${age}s — if the branch is gone:  ci-teardown retry $repo $branch"
  fi
done

# prune orphaned incoming tars (coalesce intermediates / abandoned transfers)
find "$RUNNER_BASE/incoming" -type f \( -name '*.tar' -o -name '*.changed' \) -mmin +1440 -delete 2>/dev/null || true
