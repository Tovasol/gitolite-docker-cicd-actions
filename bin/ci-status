#!/usr/bin/env bash
# ci-status - health + analytics dashboard. First thing to run when "nothing happened".
#
# Two layers, deliberately split so the tool never gets fragile (DESIGN section 3):
#   * BASICS (key/docker/slots/pending/teardowns) - pure shell + find. Always work.
#   * ANALYTICS (per-job rollups, recent, orphaned) - SQL over the run meta NDJSON via
#     DuckDB (reads the run meta.json files directly via a native glob). If duckdb
#     isn't installed, this layer is skipped with a hint; the basics still render.
#
# Usage: ci-status [repo-prefix]      # optional scope, e.g. ci-status tovasol/agent-forge
set -uo pipefail
CICD_BASE="${CICD_BASE:-/home/cicd-runner/runner}"
# shellcheck disable=SC1090
. "$CICD_BASE/bin/lib.sh"; cicd_load_config
have() { command -v "$1" >/dev/null 2>&1; }

# args: [repo-scope] [--color|--no-color]
SCOPE=""; force_color=auto
for a in "$@"; do case "$a" in
  --color)    force_color=on ;;
  --no-color) force_color=off ;;
  -*)         ;;                         # ignore unknown flags
  *)          SCOPE="$a" ;;
esac; done

# Color decision (glyphs stay ASCII always — multibyte bought nothing but breakage).
# Default auto: color on a real tty only. Force on with --color or CLICOLOR_FORCE (so
# `watch --color 'ci-status --color'` shows color); off with --no-color or NO_COLOR.
color=0
case "$force_color" in
  on)  color=1 ;;
  off) color=0 ;;
  *)   { [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-}" != dumb ]; } && color=1 ;;
esac
[ -n "${CLICOLOR_FORCE:-}" ] && [ "$force_color" != off ] && color=1
if [ "$color" = 1 ]; then
  cB=$'\033[1m'; c0=$'\033[0m'; cD=$'\033[2m'; cG=$'\033[32m'; cR=$'\033[31m'; cY=$'\033[33m'
else
  cB=''; c0=''; cD=''; cG=''; cR=''; cY=''
fi
gMid='|'; gArr='->'; bar='--------------------------------------'
ok()   { printf '  %s[ok]%s   %s\n' "$cG" "$c0" "$*"; }
no()   { printf '  %s[!!]%s   %s\n' "$cR" "$c0" "$*"; }
rule() { printf '\n%s%s %s %s%s\n' "$cB" "${bar:0:2}" "$*" "$bar" "$c0"; }
# cstatus <status> <width> -> width-padded + colored (pad first so escapes don't break
# alignment): green exit:0, yellow running, red anything else (exit:N, timeout, …).
cstatus() {
  local c=""; case "$1" in exit:0) c="$cG" ;; running) c="$cY" ;; *) c="$cR" ;; esac
  printf '%s%-*s%s' "$c" "$2" "$1" "$c0"
}

age_fmt() {  # <seconds-ago> -> compact age
  local s="${1:-}"; case "$s" in ''|*[!0-9]*) printf '?'; return ;; esac
  if   [ "$s" -ge 86400 ]; then printf '%dd' $((s/86400))
  elif [ "$s" -ge 3600 ];  then printf '%dh' $((s/3600))
  elif [ "$s" -ge 60 ];    then printf '%dm' $((s/60))
  else printf '%ds' "$s"; fi
}
dur_fmt() {  # <seconds> -> human run duration
  local d="${1:-}"; case "$d" in ''|*[!0-9]*) printf '-'; return ;; esac
  if   [ "$d" -ge 3600 ]; then printf '%dh%02dm' $((d/3600)) $(((d%3600)/60))
  elif [ "$d" -ge 60 ];   then printf '%dm%02ds' $((d/60)) $((d%60))
  else printf '%ds' "$d"; fi
}
iso_age() {  # <iso> -> seconds since (GNU date; '?' if unparseable)
  local e; e="$(date -d "${1:-}" +%s 2>/dev/null)" || { printf '?'; return; }
  printf '%s' "$(( $(date +%s) - e ))"
}

# --- analytics engine: DuckDB reads the run meta.json files DIRECTLY via a native glob —
# no concatenation, no cache file, no ingest plumbing. `filename` yields each run's dir;
# `ignore_errors` + the `schema` filter drop any partial/corrupt meta. DuckDB's parallel
# JSON reader is fast (~3 queries over 500 runs ≈ 0.13s), so we just re-glob per query.
# A query references the `data` CTE; runsql prepends it. read_json over an empty glob
# errors (suppressed) -> empty output -> the sections show "(no runs yet)".
ENGINE=none; have duckdb && ENGINE=duckdb
RUNS_GLOB="$RUNNER_BASE/runs/${SCOPE:+$SCOPE/}**/meta.json"
DATA_CTE="WITH data AS (SELECT *, regexp_replace(filename,'/meta\.json\$','') AS dir
  FROM read_json('$RUNS_GLOB', format='newline_delimited', filename=true, ignore_errors=true, union_by_name=true)
  WHERE schema IS NOT NULL)"
runsql() { duckdb -noheader -list -separator $'\t' -c "$DATA_CTE $1" 2>/dev/null; }  # <query on `data`>

# =============================== render =====================================
# Buffer the whole report and flush ONCE, so it snaps onto the screen instead of
# dribbling section-by-section (each docker/duckdb call adds latency) over ssh + screen.
# Color was already decided above against the real tty (fd1), so capturing is safe.
exec 3>&1; _BUF="$(mktemp)"; trap 'cat "$_BUF" >&3 2>/dev/null; rm -f "$_BUF"' EXIT; exec >"$_BUF"

printf '%s== cicd-runner ==%s  %s%s\n' "$cB" "$c0" "$(_ts)" "${SCOPE:+   scope=$SCOPE}"

rule health
if [ -s "$SOPS_AGE_KEY_FILE" ]; then ok "age key loaded ($SOPS_AGE_KEY_FILE)"
else no "age key NOT loaded - run: unlock-ci   (did the box reboot?)"; fi
[ -n "${DOCKER_HOST:-}" ] && export DOCKER_HOST
if docker info >/dev/null 2>&1; then ok "docker reachable (rootless)"
else no "docker NOT reachable (DOCKER_HOST=${DOCKER_HOST:-unset}) - rootless dockerd up?"; fi
printf '  slots %s/%s free   analytics engine: %s\n' \
  "$(ls "$RUNNER_BASE/slots" 2>/dev/null | wc -l | tr -d ' ')" "${MAX_JOBS}" \
  "$([ "$ENGINE" = none ] && echo 'none - install duckdb (run fetch-tools.sh)' || echo "$ENGINE")"

# --- jobs: per (repo,job) rollup -------------------------------------------------
rule "jobs"
# coalesce nullable columns -> '-' so no TSV field is ever empty (empty fields collapse
# under tab-IFS `read` and shift columns). running rows have null duration; never-green
# jobs have null last_green; etc.
# DuckDB is strict-typed (start parses as TIMESTAMP): strftime for date strings,
# ::VARCHAR for numbers shown as text. The window goes in a subquery (the data CTE is
# prepended by runsql, so the query itself can't open another top-level WITH).
JOBS_SQL="SELECT repo, job,
  max(CASE WHEN rn=1 THEN status END),
  coalesce(max(CASE WHEN rn=1 THEN duration_s END)::VARCHAR,'-'),
  coalesce(strftime(max(CASE WHEN rn=1 THEN start END),'%Y-%m-%dT%H:%M:%SZ'),'-'),
  count(*),
  sum(CASE WHEN exit IS NOT NULL AND exit<>0 THEN 1 ELSE 0 END),
  coalesce(strftime(max(CASE WHEN exit=0 THEN start END),'%Y-%m-%d'),'-'),
  coalesce(strftime(max(CASE WHEN exit IS NOT NULL AND exit<>0 THEN start END),'%Y-%m-%d'),'-')
FROM (SELECT *, row_number() OVER (PARTITION BY repo,job ORDER BY start_ns DESC) rn FROM data)
GROUP BY repo, job ORDER BY repo, job;"
if [ "$ENGINE" = none ]; then
  echo "  (duckdb not installed - run fetch-tools.sh; needed for per-job rollups)"
else
  printf '  %s%-34s %-9s %5s %7s %4s %4s %-11s %-11s%s\n' "$cD" \
    JOB STATUS AGE DUR RUNS FAIL LAST-GREEN LAST-RED "$c0"
  rows="$(runsql "$JOBS_SQL")"
  if [ -z "$rows" ]; then echo "  (no runs yet)"; else
    printf '%s\n' "$rows" | while IFS=$'\t' read -r repo job st dur start n fail green red; do
      [ -n "$job" ] || continue
      printf '  %-34s %s %5s %7s %4s %4s %-11s %-11s\n' \
        "$repo/$job" "$(cstatus "$st" 9)" "$(age_fmt "$(iso_age "$start")")" "$(dur_fmt "$dur")" \
        "$n" "$fail" "${green:--}" "${red:--}"
    done
  fi
fi

# --- recent runs -----------------------------------------------------------------
rule "recent runs"
REC_SQL="SELECT status, coalesce(duration_s::VARCHAR,'-'),
  coalesce(strftime(start,'%Y-%m-%dT%H:%M:%SZ'),'-'), job, branch, substr(sha,1,8), dir
FROM data ORDER BY start_ns DESC LIMIT ${CI_STATUS_RECENT:-12};"
if [ "$ENGINE" = none ]; then
  find "$RUNNER_BASE/runs" -type f -name meta.json -printf '%T@ %h\n' 2>/dev/null \
    | sort -rn | head -12 | while read -r _ d; do printf '  %s\n' "${d#"$RUNNER_BASE"/}"; done
else
  printf '  %s%-9s %7s %-20s %-20s %-9s %s%s\n' "$cD" STATUS DUR STARTED "JOB${gMid}BRANCH" SHA RUN-DIR "$c0"
  runsql "$REC_SQL" | while IFS=$'\t' read -r st dur start job branch sha dir; do
    [ -n "$st" ] || continue
    printf '  %s %7s %-20s %-20s %-9s %s%s%s\n' \
      "$(cstatus "$st" 9)" "$(dur_fmt "$dur")" "$start" "${job}${gMid}${branch}" "$sha" "$cD" "${dir#"$RUNNER_BASE"/}" "$c0"
  done
fi
printf '  %s%s cat <run-dir>/output.log   %s   ci-log [repo] [job]  jumps to the newest%s\n' "$cD" "$gArr" "$gMid" "$c0"

# --- orphaned (status=running) ---------------------------------------------------
if [ "$ENGINE" != none ]; then
  orph="$(runsql "SELECT repo,job,branch,coalesce(strftime(start,'%Y-%m-%dT%H:%M:%SZ'),'-') FROM data WHERE status='running' ORDER BY start_ns DESC;")"
  if [ -n "$orph" ]; then
    rule "running / possibly orphaned"
    printf '%s\n' "$orph" | while IFS=$'\t' read -r repo job branch start; do
      [ -n "$job" ] || continue
      a="$(iso_age "$start")"; flag=""; case "$a" in ''|*[!0-9]*) ;; *) [ "$a" -gt 7200 ] && flag="  ${cR}<- stale >2h${c0}" ;; esac
      printf '  %-34s %-16s started %s (%s ago)%s\n' "$repo/$job" "$branch" "$start" "$(age_fmt "$a")" "$flag"
    done
  fi
fi

# --- pending (target != last) ----------------------------------------------------
pend="$(find "$RUNNER_BASE/queue" -name target 2>/dev/null | while read -r t; do
  g="$(dirname "$t")"; [ "$(cat "$t" 2>/dev/null)" != "$(cat "$g/last" 2>/dev/null)" ] && \
    printf '  %s -> %s\n' "${g#"$RUNNER_BASE"/queue/}" "$(cat "$t")"; done)"
if [ -n "$pend" ]; then rule "pending (target != last - ci-recover will retry)"; printf '%s\n' "$pend"; fi

# --- failed teardowns ------------------------------------------------------------
td="$(find "$RUNNER_BASE/envs" -name teardown-failed 2>/dev/null)"
if [ -n "$td" ]; then
  rule "FAILED teardowns (need operator - ci-teardown retry|abandon)"
  printf '%s\n' "$td" | while read -r f; do
    d="$(dirname "$f")"; printf '  %s\n' "${d#"$RUNNER_BASE"/envs/}"; sed 's/^/      /' "$f"
  done
fi
