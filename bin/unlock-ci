#!/usr/bin/env bash
# unlock-ci — load a runner age key into the ramfs key dir (cleared on reboot). Run once per
# boot PER KEY. The target slot is chosen by the key's OWN public recipient (identity-routed),
# NOT by a name you type — so a fat-fingered/omitted name can't put prod's key in dev's slot.
#   piped (recommended — never displayed, never in history):
#       pass show gitolite-ci/age-key-prod | ssh cicd-runner@vps unlock-ci
#   gpg-encrypted file at rest (optional, §25):
#       unlock-ci            # decrypts $CICD_AGE_ENC if present (legacy single-key path)
#
# Routing: derive the pub, match it against AGE_RECIPIENT_<env> (env in AGE_ENVS, from the
# host-owned runner.conf). Match -> $AGE_KEY_DIR/<env>.age. A key that matches the EXPLICIT
# AGE_LEGACY_RECIPIENT (optional, for repos still on a single secrets.enc.yaml) -> the legacy
# slot $SOPS_AGE_KEY_FILE. Anything else is REFUSED (no silent fallback) — an unmatched key is
# almost always a mistyped recipient, which must not silently misfile a tier key.
set -euo pipefail
CICD_BASE="${CICD_BASE:-/home/cicd-runner/runner}"
# shellcheck disable=SC1090
. "$CICD_BASE/bin/lib.sh"; cicd_load_config

KEYDIR="${AGE_KEY_DIR:-$(dirname "$SOPS_AGE_KEY_FILE")}"
ENC="${CICD_AGE_ENC:-$CICD_BASE/etc/age-key.gpg}"   # optional gpg-at-rest blob

[ -d "$KEYDIR" ] || install -d -m700 "$KEYDIR"
mountpoint -q "$KEYDIR" 2>/dev/null || log "WARN: $KEYDIR is not a mountpoint (expected ramfs — see SOP §2.5)"
umask 077

# 1) read the key to a temp file (never named on the cmdline), then derive its public recipient.
tmp="$(mktemp "$KEYDIR/.unlock.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
if [ ! -t 0 ]; then
  cat > "$tmp"                                       # key piped on stdin (e.g. from pass)
elif [ -f "$ENC" ]; then
  export GPG_TTY="${GPG_TTY:-$(tty || true)}"
  gpg --decrypt "$ENC" > "$tmp"
else
  die "no key supplied. pipe it:  pass show gitolite-ci/age-key-<env> | unlock-ci   (or set up $ENC)"
fi
pub="$(age-keygen -y "$tmp" 2>/dev/null || true)"
[ -n "$pub" ] || die "not a valid age key — nothing loaded"

# 2) route by identity: which env (if any) declares this pub as its recipient?
matched=""
for e in ${AGE_ENVS:-}; do
  case "$e" in *[!a-z0-9-]*|'') die "invalid env '$e' in AGE_ENVS — refusing" ;; esac
  vn="AGE_RECIPIENT_$e"
  if [ "$pub" = "${!vn:-}" ]; then matched="$e"; break; fi
done
if [ -n "$matched" ]; then
  DEST="$KEYDIR/$matched.age"
elif [ -n "${AGE_LEGACY_RECIPIENT:-}" ] && [ "$pub" = "$AGE_LEGACY_RECIPIENT" ]; then
  # legacy single-key slot (pre-per-tier repos), but ONLY for the EXPLICITLY pinned key.
  DEST="$SOPS_AGE_KEY_FILE"; matched="legacy"
else
  # No silent fallback: an unmatched key is almost always a mistyped AGE_RECIPIENT_* (which would
  # otherwise misfile a tier key into the legacy slot). Refuse loudly; load nothing.
  die "unlock-ci: pub $pub matches no AGE_RECIPIENT_* (or AGE_LEGACY_RECIPIENT) — refusing. Check runner.conf recipients; nothing loaded."
fi

# 3) atomic install into the resolved slot (600, ramfs).
install -m600 "$tmp" "$DEST"
log "runner key loaded into $DEST  (env: ${matched:-legacy}, pub: $pub)  — clears on reboot"
cicd_audit key-unlock "env=${matched:-legacy}" "pub=$pub" "dest=$DEST" "by=$(id -un 2>/dev/null || echo '?')"

# key is now available → re-run anything deferred while it was missing (deferred-recovery,
# §10.6/§33). ci-recover re-triggers every group whose target != last (no-op if none).
if [ -x "$CICD_BASE/bin/ci-recover" ]; then
  setsid "$CICD_BASE/bin/ci-recover" </dev/null >>"${RUNNER_BASE:-$CICD_BASE}/runner.log" 2>&1 &
  log "triggered ci-recover (retries any pushes deferred while key was missing)"
fi
