#!/usr/bin/env bash
# unlock-ci — load the runner's age key into the ramfs key file (cleared on reboot).
# Run once per boot. Supply the key one of two ways:
#   piped (recommended — never displayed, never in history):
#       pass show ci/age-runner | ssh cicd-runner@vps unlock-ci
#   gpg-encrypted file at rest (optional, §25):
#       unlock-ci            # decrypts $CICD_AGE_ENC if present
set -euo pipefail
CICD_BASE="${CICD_BASE:-/home/cicd-runner/runner}"
# shellcheck disable=SC1090
. "$CICD_BASE/bin/lib.sh"; cicd_load_config

DEST="$SOPS_AGE_KEY_FILE"; DDIR="$(dirname "$DEST")"
ENC="${CICD_AGE_ENC:-$CICD_BASE/etc/age-key.gpg}"   # optional gpg-at-rest blob

[ -d "$DDIR" ] || install -d -m700 "$DDIR"
mountpoint -q "$DDIR" 2>/dev/null || log "WARN: $DDIR is not a mountpoint (expected ramfs — see SOP §2.5)"
umask 077

if [ ! -t 0 ]; then
  cat > "$DEST"                                     # key piped on stdin (e.g. from pass)
elif [ -f "$ENC" ]; then
  export GPG_TTY="${GPG_TTY:-$(tty || true)}"
  gpg --decrypt "$ENC" > "$DEST"
else
  die "no key supplied. pipe it:  pass show ci/age-runner | unlock-ci   (or set up $ENC)"
fi
chmod 600 "$DEST"

# sanity: must be a valid age identity
pub="$(age-keygen -y "$DEST" 2>/dev/null || true)"
[ -n "$pub" ] || { rm -f "$DEST"; die "not a valid age key — nothing loaded"; }
log "runner key loaded into $DEST  (pub: $pub)  — clears on reboot"
cicd_audit key-unlock "pub=$pub" "by=$(id -un 2>/dev/null || echo '?')"

# key is now available → re-run anything deferred while it was missing (deferred-recovery,
# §10.6/§33). ci-recover re-triggers every group whose target != last (no-op if none).
if [ -x "$CICD_BASE/bin/ci-recover" ]; then
  setsid "$CICD_BASE/bin/ci-recover" </dev/null >>"${RUNNER_BASE:-$CICD_BASE}/runner.log" 2>&1 &
  log "triggered ci-recover (retries any pushes deferred while key was missing)"
fi
