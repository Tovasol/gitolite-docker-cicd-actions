#!/usr/bin/env bash
# gitolite post-receive CI hook. CANONICAL SOURCE — this file is copied verbatim into
# the gitolite-admin repo as local/hooks/repo-specific/cicd and wired with
# `option hook.post-receive = echo cicd` (conf/gitolite.conf). Deployed by pushing
# gitolite-admin. If you edit this file, re-sync that copy.
# Runs as the GIT user. ARCHIVE-PUSH model (DESIGN §31): the hook PRODUCES the source
# (git archive) and PUSHES it through the sudo bridge to cicd-ingest — the runner has
# zero repo access. Self-contained (sources no runner files). Opt-in: only repos with
# .gitolite/ci.yml are processed. Fast + non-blocking (blocks only for the transfer).
set -euo pipefail

CICD_BASE="${CICD_BASE:-/home/cicd-runner/runner}"
RUNNER_USER="${CICD_RUNNER_USER:-cicd-runner}"
[ -n "${GL_REPO:-}" ] || exit 0
BARE="$PWD"                                    # gitolite sets cwd to the bare repo
ZERO=0000000000000000000000000000000000000000
PUSHER="${GL_USER:-unknown}"

git_dir() { git --git-dir="$BARE" "$@"; }
have_ci() { [ "$1" = "$ZERO" ] && return 1; git_dir cat-file -e "$1:.gitolite/ci.yml" 2>/dev/null; }

while read -r oldrev newrev refname; do
  case "$refname" in refs/heads/*) ;; *) continue ;; esac
  branch="${refname#refs/heads/}"

  if   [ "$oldrev" = "$ZERO" ]; then event=create; marker="$newrev"; srcsha="$newrev"
  elif [ "$newrev" = "$ZERO" ]; then event=delete; marker="$oldrev"; srcsha="$oldrev"
  else                                event=push;   marker="$newrev"; srcsha="$newrev"
  fi
  # opt-in gate: the marker commit's tree must contain .gitolite/ci.yml
  have_ci "$marker" || continue

  # changed-file list (the runner can't diff — it has no repo). create = whole tree.
  if [ "$event" = "create" ]; then changed="$(git_dir ls-tree -r --name-only "$newrev" 2>/dev/null || true)"
  elif [ "$event" = "delete" ]; then changed=""
  else changed="$(git_dir diff --name-only "$oldrev" "$newrev" 2>/dev/null || true)"
  fi

  # Frame: line1 = base64(changed); rest = the tar. Pipe through sudo to cicd-ingest.
  # Objects for srcsha still exist (gc runs after hooks), so `git archive` works even
  # for the delete case (oldrev). Blocks only for the archive transfer; build detaches.
  {
    printf '%s\n' "$(printf '%s' "$changed" | base64 | tr -d '\n')"
    git_dir archive --format=tar "$srcsha"
  } | sudo -n -u "$RUNNER_USER" "$CICD_BASE/bin/cicd-ingest" \
        "$GL_REPO" "$branch" "$event" "$newrev" "$oldrev" "$PUSHER" \
        >/dev/null 2>&1 || true
done

exit 0
