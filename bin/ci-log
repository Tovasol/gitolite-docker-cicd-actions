#!/usr/bin/env bash
# ci-log - show the newest run's details (meta + cmd + full output.log). Scope by repo
# and/or a job-name substring; -f to follow a live run.
#
#   ci-log                       # newest run, any repo/job
#   ci-log tovasol/agent-forge    # newest run for a repo
#   ci-log tovasol/agent-forge deploy-site      # newest deploy-site run
#   ci-log tovasol/agent-forge deploy-site -f   # follow it live
set -uo pipefail
usage() { cat <<'EOF'
ci-log - show the newest run's details: meta + cmd + full output.log.

usage: ci-log [RUN-DIR | repo [job]] [-f]
  RUN-DIR  an exact run dir - copy-paste the RUN-DIR column straight from ci-status
  repo     else: scope to a repo prefix    (e.g. tovasol/agent-forge)
  job      else: filter by job substring   (e.g. deploy-site) - resolves the NEWEST
  -f       follow the log live (tail -f)
  -h, --help

examples:
  ci-log /home/cicd-runner/runner/runs/tovasol/agent-forge/<run-id>   # exact run (paste RUN-DIR)
  ci-log                                                             # newest run, any repo/job
  ci-log tovasol/agent-forge deploy-site                             # newest deploy-site run
  ci-log tovasol/agent-forge deploy-site -f                          # follow it live
EOF
}
case "${1:-}" in -h|--help) usage; exit 0 ;; esac

CICD_BASE="${CICD_BASE:-/home/cicd-runner/runner}"
# shellcheck disable=SC1090
. "$CICD_BASE/bin/lib.sh"; cicd_load_config

repo="${1:-}"; job="${2:-}"; follow=0
for a in "$@"; do [ "$a" = "-f" ] && follow=1; done
[ "$repo" = "-f" ] && repo=""; [ "$job" = "-f" ] && job=""

if [ -n "${1:-}" ] && [ -f "${1%/}/meta.json" ]; then
  # arg 1 is an explicit RUN-DIR (copy-paste the RUN-DIR column from ci-status) -> show it
  dir="${1%/}"
else
  root="$RUNNER_BASE/runs"; [ -n "$repo" ] && root="$root/$repo"
  # else: newest run dir, optionally filtered by a job substring in the path. Sort by the
  # leaf run-id (<ts>-<sha8>-<job>) - the ISO-compact ts sorts chronologically. Portable
  # (no GNU-only find -printf): works on the box and any POSIX find.
  sel="$(find "$root" -type f -name meta.json 2>/dev/null | sed 's#/meta\.json$##')"
  [ -n "$job" ] && sel="$(printf '%s\n' "$sel" | grep -- "$job" || true)"
  dir="$(printf '%s\n' "$sel" | awk -F/ 'NF{print $NF"\t"$0}' | sort -r | head -1 | cut -f2-)"
  [ -n "$dir" ] && [ -d "$dir" ] || { echo "no runs found${repo:+ for $repo}${job:+ (job~$job)}"; exit 1; }
fi

printf '\033[1m-- run: %s --\033[0m\n' "${dir#"$RUNNER_BASE"/}"
# pretty key=value view via duckdb -line; plain cat if duckdb absent. CAPTURE the output
# (so duckdb's stdout is a pipe, not the tty) — otherwise duckdb probes the terminal
# background (OSC 11) and the reply (`11;rgb:…`) pollutes the prompt after the log.
if command -v duckdb >/dev/null 2>&1 \
   && _m="$(duckdb -line -c "SELECT * FROM read_json('$dir/meta.json', format='newline_delimited')" 2>/dev/null)" \
   && [ -n "$_m" ]; then
  printf '%s\n' "$_m"
else
  cat "$dir/meta.json"; echo
fi
[ -f "$dir/cmd" ] && { printf '\n\033[1m-- cmd --\033[0m\n'; cat "$dir/cmd"; }
printf '\n\033[1m-- output.log --\033[0m\n'
# -F (not -f): follow BY NAME, retrying if output.log doesn't exist yet (a just-started
# run writes meta before the container's first byte) or gets rotated.
if [ "$follow" = 1 ]; then tail -F "$dir/output.log" 2>/dev/null; else cat "$dir/output.log" 2>/dev/null || echo "(no output.log)"; fi
