# OPERATOR-GLOBAL email fallback for CI failure alerts (optional).
# Install as /etc/cicd-runner/notify.env  (chmod 640, root:cicd-runner).
# Simple KEY=VAL only (no shell features). Reuses your Google App Password — the
# SAME one Plausible CE uses. OPTIONAL last-resort fallback only: per-tier secrets
# (repo's sops ci/secrets.<env>.enc.yaml) OVERRIDE these key-by-key. Discouraged for
# multi-repo — a repo that ships neither its own creds nor this file simply doesn't email.
SMTP_HOST_ADDR=smtp.gmail.com
SMTP_HOST_PORT=587
SMTP_USER_NAME=hello@tovasol.com
SMTP_USER_PWD="your-16-char-app-password"
MAILER_EMAIL=hello@tovasol.com      # from + default recipient
# NOTIFY_TO=alerts@example.com     # optional recipient(s); comma-separated for several:
#                                  #   NOTIFY_TO=a@example.com, b@example.com

# --- presentation / behavior (optional) ---
# SMTP_FROM_NAME=cicd-runner       # From display name
# NOTIFY_INFO=0                    # 1 = also email non-terminal info() notices
# NOTIFY_LOGLINES=30               # log-tail lines in the body
# Custom templates with {{VAR}} tokens (STATUS TAG REPO BRANCH JOB EVENT SHA
#   SHORT_SHA PUSHER MESSAGE LABEL HOST NOW LOGTAIL). Single-line only in this file
#   (\n not expanded) — for a multi-line body prefer the per-project YAML block form.
# NOTIFY_SUBJECT={{TAG}} {{REPO}}/{{BRANCH}} {{JOB}} — {{STATUS}}
# NOTIFY_BODY={{STATUS}} {{JOB}} @ {{SHORT_SHA}} by {{PUSHER}} — {{MESSAGE}}
