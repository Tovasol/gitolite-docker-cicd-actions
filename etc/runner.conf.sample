# cicd-runner configuration — copy to /etc/cicd-runner/runner.conf (or
# $RUNNER_BASE/etc/runner.conf) and edit. Sourced by every script.
# Plain shell; no spaces around '='.

# --- identity / paths ---
RUNNER_USER=cicd-runner
RUNNER_BASE=/home/cicd-runner/runner          # queue/, runs/, cache/, envs/, slots/
#GIT_REPO_BASE=/home/git/repositories         # DECLARED BUT INERT — no code reads it today
                                              #   (documented location of the bare repos only).

# user-local tool dir (sops, yq, age) — ABSOLUTE so the runner finds them under sudo
# (sudo resets PATH to secure_path; the runner re-prepends this). No /usr/local, no root.
LOCAL_BIN=/home/cicd-runner/.local/bin

# --- secrets (sops + age) ---
# LEGACY single key slot: used for repos still on one ci/secrets.enc.yaml. `unlock-ci` writes a
# piped key here ONLY if its pub equals AGE_LEGACY_RECIPIENT below (explicit — never a fallback).
SOPS_AGE_KEY_FILE=/run/ci-keys/age-keys.txt
SHM_DIR=/dev/shm                              # tmpfs for transient decrypted env-files

# PER-TIER keys (per-environment secret scoping — docs/per-env-secrets.md). A repo with
# ci/secrets.<env>.enc.yaml is decrypted with ONLY $AGE_KEY_DIR/<env>.age (the runner never
# loads a shared master), so a lower tier can't decrypt a higher tier's blob. `unlock-ci`
# routes each piped key to its slot by IDENTITY: it derives the key's public recipient and
# matches it against AGE_RECIPIENT_<env> here — so you can't mis-file prod's key as dev's.
AGE_KEY_DIR=/run/ci-keys                       # ramfs; holds <env>.age (+ the legacy file above)
AGE_ENVS="dev qa prod"                         # tiers that have their own key
# Public recipients (age1…) of each tier's key. Fill from `age-keygen -y <key>`. NOT secret —
# but keep runner.conf write-controlled (operator-owned); a tampered map could mis-route a key.
AGE_RECIPIENT_dev=age1REPLACE_dev_public_recipient
AGE_RECIPIENT_qa=age1REPLACE_qa_public_recipient
AGE_RECIPIENT_prod=age1REPLACE_prod_public_recipient
# OPTIONAL legacy key: only set if some repo still uses a single ci/secrets.enc.yaml. `unlock-ci`
# routes the key with THIS pub to the legacy SOPS_AGE_KEY_FILE slot. A key matching NEITHER a
# tier recipient NOR this is REFUSED (no silent fallback -> a mistyped recipient can't misfile it).
#AGE_LEGACY_RECIPIENT=age1REPLACE_legacy_public_recipient

# Branch -> env resolution. DEFAULT env = sanitized branch name (dev->dev, feat/x->feat-x). Set a
# host-side map ONLY to ALIAS a branch whose name differs from its env (e.g. main->prod). The map
# is operator-owned; the pushed tree can't influence it. See etc/environments.map.sample.
CICD_ENV_MAP=/home/cicd-runner/runner/etc/environments.map   # default: $RUNNER_BASE/etc/environments.map
# OPTIONAL gpg-at-rest key blob: `unlock-ci` with no piped key decrypts THIS with gpg (§25). Leave
# unset to only ever load keys via the pipe form (pass ... | unlock-ci).
#CICD_AGE_ENC=/home/cicd-runner/runner/etc/age-key.gpg        # default: $CICD_BASE/etc/age-key.gpg

# --- concurrency ---
MAX_JOBS=4                                     # global cap on simultaneous docker runs
SLOT_WAIT_SECS=2                               # poll interval while waiting for a slot

# --- defaults (overridable per-job in .gitolite/ci.yml) ---
DEFAULT_IMAGE=node:20-alpine
DEFAULT_TIMEOUT=900                            # seconds; wall-clock kill
TIMEOUT_MAX=86400                              # hard ceiling on a job's timeout (seconds): the
                                               # per-job value is clamped to this, and 0/garbage
                                               # falls back to DEFAULT_TIMEOUT (can't disable kill)
DEFAULT_MEMORY=2g
DEFAULT_PIDS=512
DEFAULT_NETWORK=bridge                         # bridge | none

# Per-container cgroup limits (--memory/--pids-limit) need cgroup v2 + systemd under ROOTLESS
# docker. The runner AUTO-DETECTS enforcement (`docker info` warns "No memory limit support"
# etc. when it can't) and falls back to POSIX ulimits, which work WITHOUT cgroups: nproc blunts
# fork bombs, fsize blunts disk fill. So you get the best available limits per host, and the
# config self-upgrades when you move to a cgroup-v2/systemd box. See DESIGN §29.
RESOURCE_LIMITS=auto                            # auto = detect (default) | 1 = force cgroup | 0 = no cgroup attempt
ULIMIT_NPROC=1024                               # fallback process cap per job (fork-bomb blunt) when no cgroup pids
ULIMIT_FSIZE=2147483648                         # fallback single-file size cap in bytes (disk-fill blunt); 2 GiB

# --- dependency cache (ONE global, multi-ecosystem, content-addressed; DESIGN §32) ---
# All package managers (npm/pnpm/yarn/bun/pip/poetry/uv/composer/go/cargo/ruby/nuget/
# gradle/maven/deno/elixir) cache into the single $RUNNER_BASE/cache volume via a
# static env block injected by the runner — automatic, no per-project wiring. The
# prune-disk reaper age-evicts then size-caps it (the only formerly-unbounded vector).
CACHE_MAX_AGE_DAYS=30          # delete cache entries untouched this long
CACHE_MAX_GB=20                # then size-cap the whole cache (LRU eviction)
# Cache isolation. 'shared' (default) = one global cache for max dedup. 'per-repo' gives each
# repo its OWN cache subtree — closes cross-repo code-exec via shared tool config (CARGO_HOME,
# GRADLE_USER_HOME, …), at the cost of dedup. Use per-repo if you run mutually-distrusting repos.
CACHE_ISOLATION=shared        # shared | per-repo
MASK_MAX_RULES=500            # cap secret-redaction rules per job (bounds a pathological secrets
                              #   file from forking the mask builder / sed thousands of times)
LOG_MAX_BYTES=52428800        # cap per-run output.log bytes (50 MiB). The container --ulimit fsize
                              #   does NOT bound this (the append runs host-side), so a `run: yes`
                              #   flood would fill the disk; output past the cap is dropped. Raise
                              #   for genuinely log-heavy builds. Total disk: use a quota'd FS.

# --- behavior ---
#CANCEL_IN_PROGRESS=0                          # DECLARED BUT INERT — runs always coalesce today.
LOG_RETENTION_DAYS=30                          # delete run logs/metadata older than this (ci-log/status)
DELETE_SUPERSEDES=1                            # a branch-delete cancels/overrides a pending deploy
#TRUSTED_BRANCHES=                             # DECLARED BUT INERT — is_trusted_branch is unused today.

# --- ephemeral-env reaper (archive-push: runner has no repo access, §31) ---
# The git hook tears down on EVERY gitolite branch delete. reap-envs only catches the
# rare env whose branch vanished WITHOUT a hook event; it can't check branch liveness
# (no repo access), so it uses inactivity age.
REPORT_STALE_DAYS=30                           # log envs idle this long as "verify + ci-teardown"
AUTO_REAP_STALE_DAYS=0                          # 0 = report only; >0 = auto-teardown after N idle days

# --- audit log (append-only, hash-chained / tamper-evident) ---
# Every ingest / job-start / job-end / key-unlock is recorded with hash=sha256(prev+payload),
# so any edit, delete, or reorder of a past line breaks the chain. Inspect with `ci-audit
# verify` / `ci-audit tail`. Grows unbounded — rotate it yourself if needed (the hash chain
# tolerates truncating from the FRONT only if you keep the new first line's prev as a new root).
AUDIT_ENABLED=1                                # 1 = record security events; 0 = off
AUDIT_LOG=/home/cicd-runner/runner/audit.log   # default: $RUNNER_BASE/audit.log
#AUDIT_LOCK_MAX_SPINS=300                       # serialization spin cap where flock is absent (tuning)
#AUDIT_LOCK_STALE_SECS=30                       # reclaim a leaked mkdir-mutex older than this (tuning)

# --- retries + notify are NOT runner concerns ---
# They live in the ci/*.sh script via the mounted /cicd/lib.sh helpers
# (retry, notify_success/error). The runner owns only the safety bounds
# (timeout/memory/pids/network) + notify DELIVERY (below). See DESIGN §28.
NOTIFY_BACKSTOP=1             # 1 = email on a job FAILURE that emitted no script notify
                             #     (catches OOM/SIGKILL + scripts that forgot to notify)

# --- docker context (rootless) ---
# The CLI must target the rootless daemon. Set DOCKER_HOST for the cicd-runner user.
DOCKER_HOST=unix:///run/user/__UID__/docker.sock   # install.sh fills __UID__

# --- notifications ---
# Delivery handler; args: <group> <status> <logpath>. REQUIRED for ANY delivery — if unset, the
# runner emits NOTHING (notify_*/die + the failure backstop are all silently dropped). The runner
# passes the job's decrypted (resolved-tier) secrets so the handler can use PER-PROJECT SMTP creds
# from ci/secrets.<env>.enc.yaml, else the optional host default below. Handlers: notify-email, notify-wall.
NOTIFY_CMD="/home/cicd-runner/runner/bin/notify-email"
# OPTIONAL operator-global SMTP fallback file for repos that ship no SMTP creds of their own.
# notify-email reads project(tier) creds first, then this. Discouraged for multi-repo (each repo
# should carry its own per-tier creds); a repo with neither simply doesn't email.
#CICD_NOTIFY_HOST_ENV=/etc/cicd-runner/notify.env    # default shown
